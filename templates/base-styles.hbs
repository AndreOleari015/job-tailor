{{!--
  The shared visual language of both documents, lifted from the standalone
  cv.html so a rendered CV and a rendered cover letter read as one set.
  System font stack only: no web fonts, no network request at render time.
--}}
  @page { size: A4; margin: 14mm 16mm; }

  :root {
    --ink: #1a1a1a;
    --muted: #555;
    --rule: #d4d4d4;
  }

  * { box-sizing: border-box; }

  body {
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 10pt;
    line-height: 1.42;
    color: var(--ink);
    margin: 0 auto;
    max-width: 190mm;
    padding: 10mm 6mm;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }

  header { margin-bottom: 14px; }

  h1 {
    font-size: 21pt;
    letter-spacing: 0.5px;
    margin: 0 0 2px;
    font-weight: 600;
  }

  .title {
    font-size: 11pt;
    color: var(--muted);
    margin: 0 0 8px;
    font-weight: 500;
  }

  .contact {
    font-size: 8.8pt;
    color: var(--muted);
    line-height: 1.6;
  }
  .contact span::after { content: "  ·  "; }
  .contact span:last-child::after { content: ""; }
  .contact a { color: var(--muted); text-decoration: none; }

  h2 {
    font-size: 9pt;
    text-transform: uppercase;
    letter-spacing: 1.4px;
    font-weight: 700;
    margin: 18px 0 8px;
    padding-bottom: 3px;
    border-bottom: 1px solid var(--rule);
  }

  a { color: inherit; }

  /*
    Page 1 only, so it is deliberately not position: fixed — a fixed element
    repeats on every printed page, and the stamp marks the document, not each
    sheet. A forced render must never be mistakable for a clean one.
  */
  .watermark {
    position: absolute;
    top: 6mm;
    right: 6mm;
    font-size: 9pt;
    font-weight: 700;
    letter-spacing: 1.6px;
    color: #b8b8b8;
    border: 1px solid #d8d8d8;
    border-radius: 2px;
    padding: 3px 8px;
  }
