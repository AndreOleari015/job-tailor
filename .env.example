# Copy to .env and fill in the key for the provider you actually use.
#   cp .env.example .env

# Which provider to use. Defaults to gemini.
# JOB_TAILOR_PROVIDER=gemini

# Required for the selected provider only.
GEMINI_API_KEY=
# ANTHROPIC_API_KEY=

# Model, applied to every task. Defaults per provider:
#   gemini    -> gemini-2.5-flash
#   anthropic -> claude-sonnet-4-5
# JOB_TAILOR_MODEL=

# Per-task overrides. These beat JOB_TAILOR_MODEL.
# JOB_TAILOR_EXTRACT_MODEL=gemini-2.5-flash
# JOB_TAILOR_TAILOR_MODEL=gemini-2.5-pro

# Optional overrides.
# JOB_TAILOR_MAX_TOKENS=16000
# JOB_TAILOR_MAX_RETRIES=2
# JOB_TAILOR_MIN_SCORE=40
# JOB_TAILOR_PROFILE=data/profile.yaml
# JOB_TAILOR_OUTPUT_DIR=output

# Set to 1 for provider, model and token usage on stderr, full stack traces, and
# a written transcript of every model call under output/{slug}/debug/.
# DEBUG=1
