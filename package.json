{
    "name": "job-tailor",
    "version": "0.1.0",
    "private": true,
    "description": "Tailors a CV and cover letter to a specific job description using an LLM.",
    "type": "module",
    "bin": {
        "job-tailor": "dist/cli.js"
    },
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "dev": "tsx src/cli.ts",
        "build": "tsc -p tsconfig.build.json",
        "typecheck": "tsc -p tsconfig.json",
        "test": "tsc -p tsconfig.json && vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.112.4",
        "@google/genai": "^2.13.0",
        "commander": "^15.0.0",
        "dotenv": "^17.4.2",
        "yaml": "^2.9.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/node": "^26.1.1",
        "tsx": "^4.23.1",
        "typescript": "^7.0.2",
        "vitest": "^4.1.10"
    }
}
